@model FoodTrackerApp.Models.DashboardViewModel

@{
    ViewData["Title"] = "Food Safety Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4 text-primary"><i class="bi bi-speedometer2"></i> Food Safety Dashboard</h1>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Town</label>
                    <select name="town" class="form-select">
                        <option value="">-- All Towns --</option>
                        @foreach (var t in Model.Towns)
                        {
                            <option value="@t" selected="@(Model.SelectedTown == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Risk Rating</label>
                    <select name="risk" class="form-select">
                        <option value="">-- All Risks --</option>
                        <option value="Low" selected="@(Model.SelectedRisk == "Low")">Low</option>
                        <option value="Medium" selected="@(Model.SelectedRisk == "Medium")">Medium</option>
                        <option value="High" selected="@(Model.SelectedRisk == "High")">High</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row text-center">
        <div class="col-md-4">
            <div class="card border-primary mb-3 shadow">
                <div class="card-header bg-primary text-white">Monthly Inspections</div>
                <div class="card-body">
                    <h2 class="card-title">@Model.MonthlyInspectionsCount</h2>
                    <p class="card-text text-muted">Total visits this month</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-danger mb-3 shadow">
                <div class="card-header bg-danger text-white">Monthly Fails</div>
                <div class="card-body">
                    <h2 class="card-title text-danger">@Model.MonthlyFailedCount</h2>
                    <p class="card-text text-muted">Inspections with 'Fail' outcome</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-warning mb-3 shadow">
                <div class="card-header bg-warning text-dark">Overdue Follow-ups</div>
                <div class="card-body">
                    <h2 class="card-title text-warning">@Model.OverdueFollowUpsCount</h2>
                    <p class="card-text text-muted">Open tasks past due date</p>
                </div>
            </div>
        </div>
    </div>
</div>